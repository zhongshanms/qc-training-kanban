# 把下面三行的值改成你自己的，然后把本文件重命名为 .env（去掉 .example）
# 获取方式见 README.md

COS_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxxxx
COS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 存储桶名格式：<自定义名>-<APPID>   APPID 在控制台右上角头像→账号信息
COS_BUCKET=qctraining-1250000000
# 地域：广州 ap-guangzhou / 上海 ap-shanghai / 北京 ap-beijing
COS_REGION=ap-guangzhou
